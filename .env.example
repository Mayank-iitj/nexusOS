# ============================================
# NexusOS — Environment Variables
# ============================================
# Copy this file to .env and fill in the values

# ── Application ──────────────────────────────
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000
BACKEND_URL=http://localhost:8000
API_VERSION=v1

# ── Authentication (NextAuth / Auth.js) ──────
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-nextauth-secret-here-generate-with-openssl-rand-base64-32
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret

# ── Database ─────────────────────────────────
DATABASE_URL=postgresql://nexus:nexus_password@localhost:5432/nexus_os
POSTGRES_USER=nexus
POSTGRES_PASSWORD=nexus_password
POSTGRES_DB=nexus_os

# ── Redis ────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── AI / LLM ─────────────────────────────────
OPENAI_API_KEY=sk-your-openai-api-key
GOOGLE_GEMINI_API_KEY=your-gemini-api-key
DEFAULT_LLM_PROVIDER=gemini
DEFAULT_LLM_MODEL=gemini-2.0-flash

# ── Embeddings ───────────────────────────────
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536

# ── Google Workspace ─────────────────────────
GOOGLE_WORKSPACE_CREDENTIALS=path/to/credentials.json
GMAIL_SCOPES=https://www.googleapis.com/auth/gmail.modify
CALENDAR_SCOPES=https://www.googleapis.com/auth/calendar
DRIVE_SCOPES=https://www.googleapis.com/auth/drive.readonly

# ── GitHub ───────────────────────────────────
GITHUB_TOKEN=ghp_your-github-personal-access-token
GITHUB_WEBHOOK_SECRET=your-github-webhook-secret

# ── Slack ────────────────────────────────────
SLACK_BOT_TOKEN=xoxb-your-slack-bot-token
SLACK_SIGNING_SECRET=your-slack-signing-secret
SLACK_APP_TOKEN=xapp-your-slack-app-token

# ── Jira ─────────────────────────────────────
JIRA_URL=https://your-org.atlassian.net
JIRA_EMAIL=your-email@example.com
JIRA_API_TOKEN=your-jira-api-token

# ── Notion ───────────────────────────────────
NOTION_API_KEY=ntn_your-notion-integration-token

# ── Supabase (optional, for cloud deployment)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# ── n8n Automation ───────────────────────────
N8N_URL=http://localhost:5678
N8N_API_KEY=your-n8n-api-key

# ── Monitoring ───────────────────────────────
SENTRY_DSN=https://your-sentry-dsn
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318

# ── Security ─────────────────────────────────
RATE_LIMIT_PER_MINUTE=60
ENCRYPTION_KEY=your-32-byte-encryption-key
CORS_ORIGINS=http://localhost:3000,http://localhost:3001
